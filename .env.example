# Connection string do Neon (Settings > Connection Details no painel do Neon)
DATABASE_URL="postgresql://user:password@ep-example.neon.tech/anotaplus?sslmode=require"

# Web Client ID criado no Google Cloud Console (Credentials > OAuth client ID > Web application)
# É esse ID (não o do tipo Android) que verifica o token que o app manda.
GOOGLE_WEB_CLIENT_ID="xxxxxxxxxx.apps.googleusercontent.com"

# Segredo pra assinar o JWT da nossa própria sessão (gere algo aleatório, ex: openssl rand -hex 32)
JWT_SECRET="troque-por-um-valor-aleatorio"

PORT=3000
